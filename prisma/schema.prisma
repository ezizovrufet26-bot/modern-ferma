generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String?
  role          String    @default("USER") // ADMIN, USER
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  animals       Animal[]
  staff         Staff[]
  finance       FinanceRecord[]
  feeds         FeedItem[]
  rations       Ration[]
  feedings      FeedingRecord[]
  weightRecords WeightRecord[]
}

model FeedItem {
  id            String    @id @default(cuid())
  name          String
  unit          String    @default("kg") // kg, ton, litr
  costPerUnit   Float     @default(0)    // 1 vahidin qiyməti (məs: 1 kq arpa neçəyədir?)
  stock         Float     @default(0)    // Ambardakı qalıq
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  rationItems   RationItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Ration {
  id            String    @id @default(cuid())
  name          String
  description   String?
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items         RationItem[]
  feedings      FeedingRecord[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model RationItem {
  id            String    @id @default(cuid())
  amount        Float     // Bu rasionda bu yemden ne qeder var (məs: 5 kq)
  
  rationId      String
  ration        Ration    @relation(fields: [rationId], references: [id], onDelete: Cascade)
  
  feedItemId    String
  feedItem      FeedItem  @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
}

model FeedingRecord {
  id            String    @id @default(cuid())
  date          DateTime  @default(now())
  groupName     String    // Hansı qrup yemləndi (məs: SAĞMAL 1)
  animalCount   Int       @default(0)
  frequency     Int       @default(3)    // Gündə neçə dəfə yemlənir
  completedMeals Int      @default(3)    // Neçə yemləmə tamamlanıb
  totalCost     Float     @default(0)
  
  rationId      String
  ration        Ration    @relation(fields: [rationId], references: [id])
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Animal {
  id             String               @id @default(uuid())
  tagNumber      String
  name           String?
  breed          String?
  gender         String               @default("FEMALE")
  birthDate      DateTime?
  stage          String               @default("CALF")
  groupName      String               @default("BUZOV_QRUPU")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  motherId       String?
  sireCode       String?
  mother         Animal?              @relation("MotherToChild", fields: [motherId], references: [id])
  children       Animal[]             @relation("MotherToChild")

  isPregnant          Boolean              @default(false)
  lastBreedingDate    DateTime?
  expectedCalvingDate DateTime?
  isDry               Boolean              @default(false)
  dryDate             DateTime?

  milkRecords    MilkRecord[]
  healthRecords  HealthRecord[]
  reproRecords   ReproductionRecord[]
  calvingRecords CalvingRecord[]
  vaccineRecords VaccineRecord[]
  weightRecords  WeightRecord[]

  @@unique([tagNumber, userId])
}

model WeightRecord {
  id            String    @id @default(cuid())
  date          DateTime  @default(now())
  weight        Float     // kq ilə
  note          String?
  
  animalId      String
  animal        Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MilkRecord {
  id           String   @id @default(uuid())
  animalId     String
  date         DateTime
  yieldMorning Float    @default(0)
  yieldEvening Float    @default(0)
  totalYield   Float
  createdAt    DateTime @default(now())

  animal       Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model HealthRecord {
  id          String   @id @default(uuid())
  animalId    String
  date        DateTime
  type        String
  disease     String?
  description String
  treatment   String?
  medications String?
  vetName     String?
  cost        Float    @default(0)
  createdAt   DateTime @default(now())

  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model VaccineRecord {
  id          String   @id @default(uuid())
  animalId    String
  vaccineName String
  date        DateTime
  nextDueDate DateTime?
  dose        String?
  notes       String?
  createdAt   DateTime @default(now())

  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  role        String   @default("HEKIM") // HEKIM, BAS_HEKIM, TEXNIK, ISCI
  phone       String?
  salary      Float?   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  reproRecords ReproductionRecord[]
}

model CalvingRecord {
  id          String   @id @default(uuid())
  animalId    String
  date        DateTime
  parity      Int      @default(1)
  calfGender  String   @default("FEMALE")
  calfId      String?
  notes       String?
  createdAt   DateTime @default(now())

  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model ReproductionRecord {
  id                  String    @id @default(uuid())
  animalId            String
  vetId               String?
  date                DateTime
  eventType           String
  expectedCalvingDate DateTime? 
  notes               String?
  createdAt           DateTime  @default(now())

  animal              Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  vet                 Staff?    @relation(fields: [vetId], references: [id])
}

model FinanceRecord {
  id          String   @id @default(uuid())
  date        DateTime
  type        String
  category    String
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
