generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Farm {
  id                  String          @id @default(uuid())
  name                String
  description         String?
  createdAt           DateTime        @default(now())
  subscriptionStatus  String          @default("ACTIVE")
  subscriptionExpires DateTime?
  updatedAt           DateTime        @updatedAt
  animals             Animal[]
  feeds               FeedItem[]
  feedings            FeedingRecord[]
  finance             FinanceRecord[]
  rations             Ration[]
  staff               Staff[]
  users               User[]
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String
  name            String?
  role            String          @default("FARM_USER")
  isActive        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  farmId          String?
  createdFeedings FeedingRecord[]
  createdFinance  FinanceRecord[]
  farm            Farm?           @relation(fields: [farmId], references: [id])
}

model FeedItem {
  id          String       @id @default(cuid())
  name        String
  unit        String       @default("kg")
  costPerUnit Float        @default(0)
  stock       Float        @default(0)
  minStock    Float        @default(50)
  farmId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  farm        Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  rationItems RationItem[]
}

model Ration {
  id          String          @id @default(cuid())
  name        String
  description String?
  farmId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  feedings    FeedingRecord[]
  farm        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  items       RationItem[]
}

model RationItem {
  id         String   @id @default(cuid())
  amount     Float
  rationId   String
  feedItemId String
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  ration     Ration   @relation(fields: [rationId], references: [id], onDelete: Cascade)
}

model FeedingRecord {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  groupName      String
  animalCount    Int      @default(0)
  frequency      Int      @default(3)
  completedMeals Int      @default(3)
  totalCost      Float    @default(0)
  rationId       String
  farmId         String
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id])
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  ration         Ration   @relation(fields: [rationId], references: [id])
}

model Animal {
  id                  String               @id @default(uuid())
  tagNumber           String
  name                String?
  breed               String?
  gender              String               @default("FEMALE")
  birthDate           DateTime?
  stage               String               @default("CALF")
  groupName           String               @default("BUZOV_QRUPU")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  farmId              String
  motherId            String?
  sireCode            String?
  isPregnant          Boolean              @default(false)
  lastBreedingDate    DateTime?
  expectedCalvingDate DateTime?
  isDry               Boolean              @default(false)
  dryDate             DateTime?
  mother              Animal?              @relation("MotherToChild", fields: [motherId], references: [id])
  children            Animal[]             @relation("MotherToChild")
  farm                Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  calvingRecords      CalvingRecord[]
  healthRecords       HealthRecord[]
  milkRecords         MilkRecord[]
  reproRecords        ReproductionRecord[]
  vaccineRecords      VaccineRecord[]
  weightRecords       WeightRecord[]

  @@unique([tagNumber, farmId])
}

model WeightRecord {
  id       String   @id @default(cuid())
  date     DateTime @default(now())
  weight   Float
  note     String?
  animalId String
  animal   Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model MilkRecord {
  id           String   @id @default(uuid())
  animalId     String
  date         DateTime
  yieldMorning Float    @default(0)
  yieldEvening Float    @default(0)
  totalYield   Float
  createdAt    DateTime @default(now())
  animal       Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model HealthRecord {
  id          String   @id @default(uuid())
  animalId    String
  date        DateTime
  type        String
  disease     String?
  description String
  treatment   String?
  medications String?
  vetName     String?
  cost        Float    @default(0)
  createdAt   DateTime @default(now())
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model VaccineRecord {
  id          String    @id @default(uuid())
  animalId    String
  vaccineName String
  date        DateTime
  nextDueDate DateTime?
  dose        String?
  notes       String?
  createdAt   DateTime  @default(now())
  animal      Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model Staff {
  id           String               @id @default(uuid())
  name         String
  role         String               @default("HEKIM")
  phone        String?
  salary       Float?               @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @default(now()) @updatedAt
  farmId       String
  reproRecords ReproductionRecord[]
  farm         Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
}

model CalvingRecord {
  id         String   @id @default(uuid())
  animalId   String
  date       DateTime
  parity     Int      @default(1)
  calfGender String   @default("FEMALE")
  calfId     String?
  notes      String?
  createdAt  DateTime @default(now())
  animal     Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model ReproductionRecord {
  id                  String    @id @default(uuid())
  animalId            String
  vetId               String?
  date                DateTime
  eventType           String
  expectedCalvingDate DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  vet                 Staff?    @relation(fields: [vetId], references: [id])
  animal              Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model FinanceRecord {
  id          String   @id @default(uuid())
  date        DateTime
  type        String
  category    String
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  farmId      String
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  farm        Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
}
